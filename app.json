{
  "expo": {
    "name": "Training App",
    "slug": "training-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "training-app",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trainingapp.mobile"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.trainingapp.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ]
  }
}
